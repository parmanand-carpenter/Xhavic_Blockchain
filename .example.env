# OP Stack L2 Rollup Environment Configuration
# Copy this file to .env and fill in your actual values

# ==========================================
# REQUIRED: L1 Configuration (Sepolia testnet)
# ==========================================
# Option 1: Public endpoint (no API key required - recommended for testing)
L1_RPC_URL="https://ethereum-sepolia-rpc.publicnode.com"
L1_BEACON_URL="https://ethereum-sepolia-beacon-api.publicnode.com"

# Option 2: Private endpoint (requires API key from Infura/Alchemy)
# L1_RPC_URL="https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY"
# L1_BEACON_URL="https://ethereum-sepolia-beacon-api.publicnode.com"

# ==========================================
# REQUIRED: Private Keys for Deployment & Operations
# ==========================================
# IMPORTANT: Never commit this to version control!
# Get these from your MetaMask or other self-custody wallet
# Remove the 0x prefix if present

# Deployer private key (used for deploying L1 contracts and admin operations)
PRIVATE_KEY="YOUR_DEPLOYER_PRIVATE_KEY_WITHOUT_0X_PREFIX"

# Sequencer private key (used for signing blocks)
SEQUENCER_PRIVATE_KEY="YOUR_SEQUENCER_PRIVATE_KEY_WITHOUT_0X_PREFIX"

# Batcher private key (used for posting batches to L1)
BATCHER_PRIVATE_KEY="YOUR_BATCHER_PRIVATE_KEY_WITHOUT_0X_PREFIX"

# Proposer private key (used for proposing state roots)
PROPOSER_PRIVATE_KEY="YOUR_PROPOSER_PRIVATE_KEY_WITHOUT_0X_PREFIX"

# Challenger private key (used for challenging invalid state roots)
CHALLENGER_PRIVATE_KEY="YOUR_CHALLENGER_PRIVATE_KEY_WITHOUT_0X_PREFIX"

# ==========================================
# OPTIONAL: Public IP for P2P Networking
# ==========================================
# For local testing, defaults to 127.0.0.1
# For production/testnet, run: curl ifconfig.me
P2P_ADVERTISE_IP="127.0.0.1"

# ==========================================
# OPTIONAL: Custom Configuration
# ==========================================
# Default L2 Chain ID (pick any unused number between 10000-99999)
L2_CHAIN_ID="16584"

# ==========================================
# ADVANCED: Component Environment Variables
# ==========================================
# Batcher settings (testnet)
OP_BATCHER_POLL_INTERVAL="1s"
OP_BATCHER_SUB_SAFETY_MARGIN="10"
OP_BATCHER_NUM_CONFIRMATIONS="4"
OP_BATCHER_SAFE_ABORT_NONCE_TOO_LOW_COUNT="3"

# Proposer settings
OP_PROPOSER_PROPOSAL_INTERVAL="1800s"
OP_PROPOSER_GAME_TYPE="0"
OP_PROPOSER_POLL_INTERVAL="12s"

# ==========================================
# DEVELOPMENT: Local Network (Alternative to Sepolia)
# ==========================================
# Uncomment these for local development with a local L1 network
# L1_RPC_URL="http://host.docker.internal:8545"
# L1_BEACON_URL="http://host.docker.internal:5052"
